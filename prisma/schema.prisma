generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// AUTH + API KEYS (Feature 1)
// =============================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String?
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  auditLogs     AuditLog[]
  activities    Activity[]
}

enum Role {
  ADMIN
  MANAGER
  USER
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  userId      String
  scopes      String[]  @default([])
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isRevoked   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
}

// =============================================
// WEBHOOKS (Feature 2)
// =============================================

model Webhook {
  id        String   @id @default(uuid())
  url       String
  secret    String
  events    String[]
  isActive  Boolean  @default(true)
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
}

model WebhookDelivery {
  id            String        @id @default(uuid())
  webhookId     String
  event         String
  payload       Json
  statusCode    Int?
  responseBody  String?
  attempt       Int           @default(1)
  status        DeliveryStatus @default(PENDING)
  nextRetryAt   DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime      @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([status])
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

// =============================================
// FEATURE FLAGS (Feature 3)
// =============================================

model FeatureFlag {
  id            String   @id @default(uuid())
  key           String   @unique
  name          String
  description   String?
  isEnabled     Boolean  @default(false)
  rolloutPercent Int     @default(0)
  targetUsers   String[] @default([])
  targetRoles   Role[]   @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([key])
}

// =============================================
// AUDIT TRAIL + ACTIVITY FEED (Feature 4)
// =============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  statusCode Int
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource])
  @@index([createdAt])
}

model Activity {
  id         String   @id @default(uuid())
  userId     String
  type       String
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}
